# ============================================================
# Next Home – Root .gitignore
# ============================================================

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.prod
.env.*.local
*.pem
*.key
*_private_key*
terraform.tfvars
terraform.tfvars.json
*.tfstate
*.tfstate.*
.terraform/

# ── Node.js / Backend ─────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
backend/logs/
backend/coverage/
backend/dist/
backend/.nyc_output/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Flutter / Dart / Mobile ───────────────────────────────────────────────────
mobile/.dart_tool/
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/key.properties
mobile/*.keystore
mobile/*.jks
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Runner.xcworkspace/xcshareddata/
mobile/ios/Runner.xcworkspace/xcuserdata/
mobile/**/*.g.dart
mobile/**/*.freezed.dart
mobile/**/generated_plugin_registrant.dart
mobile/lib/firebase_options.dart  # Has secrets – use .example version
mobile/google-services.json
mobile/GoogleService-Info.plist

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/settings.json          # Keep only non-personal settings
# (launch.json and tasks.json should be committed)

# ── IntelliJ / Android Studio ────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.gradle/

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Docker ────────────────────────────────────────────────────────────────────
docker/oracle/data/
docker/nginx/ssl/

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
*.bak
*.swp
*.swo

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.apk
*.aab
*.ipa
*.dSYM

# ── Oracle Wallet ─────────────────────────────────────────────────────────────
**/wallet/
**/cwallet.sso
**/tnsnames.ora
**/sqlnet.ora

# ── Keep these ────────────────────────────────────────────────────────────────
!.env.example
!backend/.env.example
!mobile/lib/firebase_options.dart.example
!mobile/google-services.json.example
