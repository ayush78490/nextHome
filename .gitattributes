# Next Home – Git attributes
# Normalize line endings

* text=auto eol=lf

# Windows scripts use CRLF
*.ps1     text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Keep binary files as-is
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.ttf     binary
*.woff    binary
*.woff2   binary
*.apk     binary
*.aab     binary
*.ipa     binary
*.keystore binary
*.jks     binary
*.zip     binary
*.gz      binary
