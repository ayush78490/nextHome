# ============================================================
# Next Home – Root .env.example
# Copy to .env and fill in your values
# ============================================================

# ── Oracle Database ───────────────────────────────────────────────────────────
ORACLE_SYS_PASSWORD=NextHome_SYS_2024!
ORACLE_APP_USER=nexthome
ORACLE_APP_PASSWORD=NextHome_App_2024!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=NextHome_Redis_2024!

# ── Backend API ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SOCKET_PORT=3001
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# For production: paste the entire JSON on one line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or point to the file:
# GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account.json

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME_sk_test_secret_key
STRIPE_WEBHOOK_SECRET=CHANGE_ME_whsec_webhook_secret
# Flutter (publishable key – safe to expose)
STRIPE_PUBLISHABLE_KEY=CHANGE_ME_pk_test_publishable_key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Oracle Cloud Infrastructure (for deployment) ─────────────────────────────
OCI_TENANCY_OCID=ocid1.tenancy.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OCI_USER_OCID=ocid1.user.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_REGION=ap-mumbai-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
